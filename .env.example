# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=your_username
DB_PASSWORD=your_password
DB_NAME=music_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# JWT Configuration (REQUERIDO - mínimo 32 caracteres)
JWT_SECRET=your-super-secret-key-at-least-32-chars-long
JWT_ACCESS_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_EXPIRES_IN=30d
JWT_ISSUER=music_app
JWT_AUDIENCE=music_app

# Google OAuth (Opcional - solo si usas Google)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=/api/auth/google/callback

# Apple Sign In (Opcional - solo si usas Apple)
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY=your-apple-private-key
APPLE_CALLBACK_URL=/api/auth/apple/callback

# External Music Service
MUSIC_SERVICE_BASE_URL=http://localhost:8000/api/v1
MUSIC_SERVICE_TIMEOUT=30000

# CORS (separar múltiples orígenes con coma)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
